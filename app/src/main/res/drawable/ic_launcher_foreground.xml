<?xml version="1.0" encoding="utf-8"?>
<!--
  SwipePlayer icon foreground (108x108dp, safe zone 72x72dp centred at 54,54).
  Design: play triangle (centre) + two swipe chevrons (top/bottom).
  All shapes white on transparent background; background layer provides colour.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
      Play triangle: right-pointing, centred in the safe zone.
      Vertices: left-top (28,24), left-bottom (28,76), right-centre (78,50)
    -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M28,24 L28,76 L78,50 Z" />

    <!--
      Swipe-up chevron (above the triangle): thick V opening upward.
      Path: left arm down → apex → right arm down, closed as filled shape.
      Gives a solid ∧ shape.
    -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M36,22 L54,10 L72,22 L68,22 L54,14 L40,22 Z" />

    <!--
      Swipe-down chevron (below the triangle): thick V opening downward.
      Gives a solid ∨ shape.
    -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M36,86 L54,98 L72,86 L68,86 L54,94 L40,86 Z" />

</vector>
